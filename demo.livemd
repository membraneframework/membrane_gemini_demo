# Membrane Gemini Demo — WebRTC + Termite

```elixir
Mix.install(
  [
    {:kino_termite, "~> 0.1.1"},
    # {:membrane_ffmpeg_swresample_plugin, "~> 0.20.5"},
    {:membrane_gemini_demo, path: __DIR__, env: :dev, override: true},
    {:boombox, path: "/Users/kidq330/repos/work/membrane/boombox", override: true}
  ]
  # lockfile: :membrane_gemini_demo
)

case System.fetch_env("LB_GEMINI_API_KEY") do
  {:ok, api_key}
    -> Application.put_env(:gemini_ex, :api_key, api_key)

  :error
    -> raise """
      A key for the Gemini Live API is required to run this example.
      Please set `GEMINI_API_KEY` in your livebook's SECRETS section.
  """
end
```

## Start the pipeline + TUI

`Gemini.TermiteMicDemo.WebRTCBridge` (under `lib/`) hosts both peer
connections in a single iframe so the browser's echo canceller sees mic
capture and `<audio>` playback on the same page.

The cell below owns the lifecycle: it kills any previous run, then spawns
a runner that builds the demo's WebRTC pipeline spec, starts the
pipeline, waits for it to enter `:playing`, then brings up the Termite
TUI. The bridge widget is rendered side-by-side with the terminal at the
bottom of the cell.

The spec is built inline here so the audio I/O — `Boombox.Bin` on both
ends, plus a resampler from Opus's 48 kHz to Gemini's 16 kHz — is
self-contained to the livebook. Compare with `Mix.Tasks.Demo` for the
native PortAudio variant.

```elixir
import Membrane.ChildrenSpec
import Membrane.Pad

alias Gemini.TermiteMicDemo
alias Membrane.{FFmpeg, RawAudio}

gemini_input_format = %RawAudio{sample_format: :s16le, channels: 1, sample_rate: 16_000}

spec_fn = fn tui_pid, source_signaling, sink_signaling ->
    [
      child(:webrtc_source, %Membrane.WebRTC.Source{signaling: source_signaling})
      |> via_out(Membrane.Pad.ref(:output, :main_audio), options: [kind: :audio])
      |> child(:input_transcoder, %Membrane.Transcoder{output_stream_format: gemini_input_format})
      |> child(:input_resampler, %Membrane.FFmpeg.SWResample.Converter{output_stream_format: gemini_input_format})
      |> child(:mute_filter, TermiteMicDemo.MuteFilter)
      |> child(:mic_visualizer, %TermiteMicDemo.VisualizerBin{
        on_samples: fn samples -> send(tui_pid, {:mic_samples, samples}) end}
      )
      |> via_in(:audio_input)
      |> child(:gemini, Membrane.Gemini.Bin)
      |> child(:event_handler, %Membrane.Debug.Filter{
        handle_event: &TermiteMicDemo.Pipeline.handle_gemini_event(&1, tui_pid)
      })
      |> child(:gemini_visualizer, %TermiteMicDemo.VisualizerBin{
        on_samples: fn samples -> send(tui_pid, {:gemini_samples, samples}) end
      })
      |> child(:output_transcoder, %Membrane.Transcoder{output_stream_format: Membrane.Opus})
      |> via_in(Membrane.Pad.ref(:input, :main_audio), options: [kind: :audio])
      |> child(:webrtc_sink, %Membrane.WebRTC.Sink{
        signaling: sink_signaling,
        tracks: [:audio]
      }),

      child(:text_source, TermiteMicDemo.TextSource)
      |> via_in(:text_input)
      |> get_child(:gemini)
    ]
  end
```

```elixir
Logger.configure(level: :debug)

runner_name = :gemini_demo_app_runner

case Process.whereis(runner_name) do
  nil ->
    :ok

  pid ->
    ref = Process.monitor(pid)
    Process.exit(pid, :shutdown)

    receive do
      {:DOWN, ^ref, :process, ^pid, _} -> :ok
    after
      5_000 -> :ok
    end
end

parent = self()

spawn(fn ->
  Process.register(self(), runner_name)

  source_signaling = Membrane.WebRTC.Signaling.new()
  sink_signaling = Membrane.WebRTC.Signaling.new()

  bridge = TermiteMicDemo.WebRTCBridge.new(source_signaling, sink_signaling)
  send(parent, {:bridge_ready, bridge})

  Gemini.TermiteMicDemo.App.start(
    spec_fn: fn tui_pid -> spec_fn.(tui_pid, source_signaling, sink_signaling) end,
    terminal_factory: fn ->
      terminal = Termite.Terminal.start(adapter: KinoTermite.Adapter, rows: 40)
      send(parent, {:terminal_ready, terminal})
      terminal
    end
  )
end)

bridge = receive do
  {:bridge_ready, bridge} -> bridge
end

terminal =
  receive do
    {:terminal_ready, t} -> t
  after
    30_000 -> raise "terminal never started (did the pipeline reach :playing?)"
  end


Kino.Layout.grid([bridge, KinoTermite.output(terminal)], boxed: true)
```

```elixir
KinoMembrane.pipeline_dashboard(pipeline)
```

After this cell runs, click **Connect** in the bridge panel and start talking.
Keyboard shortcuts in the TUI:

* `m` — mute / unmute the mic
* `d` — toggle the debug event log
* type a prompt and press Enter to send text to Gemini
* `/clear` — reset the conversation

