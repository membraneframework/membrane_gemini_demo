# Membrane Gemini Demo — WebRTC + Termite

```elixir
Mix.install(
  [
    {:kino_termite, "~> 0.1.1"},
    {:membrane_transcoder_plugin, "~> 0.4.0"},
    {:membrane_webrtc_plugin, "~> 0.26.3"},
    {:membrane_gemini_demo, path: __DIR__}
  ]
  # lockfile: :membrane_gemini_demo
)

case System.fetch_env("LB_GEMINI_API_KEY") do
  {:ok, api_key} ->
    Application.put_env(:gemini_ex, :api_key, api_key)

  :error ->
    raise """
        A key for the Gemini Live API is required to run this example.
        Please set `GEMINI_API_KEY` in your livebook's SECRETS section.
    """
end
```

## The WebRTC bridge widget

`Gemini.TermiteMicDemo.WebRTCBridge` is a `Kino.JS.Live` widget that hosts both
peer connections in one iframe (so the browser's echo canceller sees mic capture
and `<audio>` playback on the same page) and relays signalling between the JS and
the two `Membrane.WebRTC.Signaling` channels. It used to live in the mix project
under `lib/`; moving the module here is what lets `mix.exs` drop `kino` and
`membrane_webrtc_plugin`. Its JS asset still lives at `lib/assets/webrtc_bridge`.

```elixir
defmodule Gemini.TermiteMicDemo.WebRTCBridge do
  @moduledoc """
  Kino widget that hosts both peer connections in a single iframe so the
  browser's echo canceller sees mic capture and `<audio>` playback on the
  same page.
  """

  use Kino.JS, assets_path: Path.join(__DIR__, "lib/assets/webrtc_bridge")
  use Kino.JS.Live

  alias Membrane.WebRTC.Signaling

  @spec subscribe(Kino.JS.Live.t(), pid()) :: :ok
  def subscribe(bridge, pid \\ self()) do
    Kino.JS.Live.cast(bridge, {:subscribe, pid})
  end

  @spec new(Signaling.t(), Signaling.t()) :: Kino.JS.Live.t()
  def new(source_signaling, sink_signaling) do
    Kino.JS.Live.new(__MODULE__, %{source: source_signaling, sink: sink_signaling})
  end

  @impl true
  def init(%{source: source, sink: sink}, ctx) do
    Signaling.register_peer(source, message_format: :json_data)
    Signaling.register_peer(sink, message_format: :json_data)

    {:ok,
     assign(ctx,
       source: source,
       sink: sink,
       source_queue: [],
       sink_queue: [],
       drained?: false,
       subscribers: MapSet.new(),
       peer_states: %{}
     )}
  end

  @impl true
  def handle_connect(ctx) do
    payload = %{
      source_queue: Enum.reverse(ctx.assigns.source_queue),
      sink_queue: Enum.reverse(ctx.assigns.sink_queue)
    }

    {:ok, payload, assign(ctx, source_queue: [], sink_queue: [], drained?: true)}
  end

  @impl true
  def handle_event("signal_source", message, ctx) do
    Signaling.signal(ctx.assigns.source, message)
    {:noreply, ctx}
  end

  def handle_event("signal_sink", message, ctx) do
    Signaling.signal(ctx.assigns.sink, message)
    {:noreply, ctx}
  end

  def handle_event("peer_state", %{"peer" => peer, "state" => state}, ctx) do
    ctx = update(ctx, :peer_states, &Map.put(&1, peer, state))

    for pid <- ctx.assigns.subscribers, do: send(pid, {:webrtc_bridge, peer, state})

    {:noreply, ctx}
  end

  @impl true
  def handle_cast({:subscribe, pid}, ctx) do
    for {peer, state} <- ctx.assigns.peer_states, do: send(pid, {:webrtc_bridge, peer, state})

    {:noreply, update(ctx, :subscribers, &MapSet.put(&1, pid))}
  end

  @impl true
  def handle_info({:membrane_webrtc_signaling, pid, message, _meta}, ctx) do
    {channel, queue_key} =
      cond do
        pid == ctx.assigns.source.pid -> {"source_signal", :source_queue}
        pid == ctx.assigns.sink.pid -> {"sink_signal", :sink_queue}
      end

    if ctx.assigns.drained? do
      broadcast_event(ctx, channel, message)
      {:noreply, ctx}
    else
      {:noreply, update(ctx, queue_key, &[message | &1])}
    end
  end
end
```

```elixir
defmodule AwaitBridge do
  def await_connected(bridge) do
    Gemini.TermiteMicDemo.WebRTCBridge.subscribe(bridge)
    do_await_bridge(%{source?: false, sink?: false})
  end

  defp do_await_bridge(%{source?: true, sink?: true}), do: :ok

  defp do_await_bridge(state) do
    receive do
      {:webrtc_bridge, "source", "connected"} -> %{state | source?: true}
      {:webrtc_bridge, "sink", "connected"} -> %{state | sink?: true}
      _other -> state
    end
    |> do_await_bridge()
  end
end
```

## The WebRTC pipeline

`Gemini.TermiteMicDemo.Pipeline` bakes the demo's audio graph into its
`handle_init/2`: WebRTC source/sink on both ends (so the browser's echo
canceller sees mic capture and `<audio>` playback on the same page), a
resampler from Opus's 48 kHz down to Gemini's 16 kHz, and the
mute → chunk → tee → Gemini → tee middle shared with the native variant. It
mirrors the native PortAudio pipeline in `native.exs`; only the ends differ.
The caller passes the two `Membrane.WebRTC.Signaling` channels via the
`:source_signaling`/`:sink_signaling` opts, and the TUI drives it through the
`submit_text`/`reset_session`/`toggle_mute` send-helpers.

```elixir
alias Gemini.TermiteMicDemo

defmodule Gemini.TermiteMicDemo.Pipeline do
  @moduledoc """
  The WebRTC pipeline for the demo.

  Mirrors the native PortAudio pipeline in `native.exs`: it bakes its audio I/O
  spec into `handle_init/2`, notifies the TUI on `:playing`, relays the
  `:text`/`:reset_session`/`:toggle_mute` control messages to named children,
  and exposes the matching send-helpers the TUI calls. Only the ends differ —
  WebRTC source/sink plus a resampler from Opus's 48 kHz down to Gemini's
  16 kHz. The caller supplies the two `Membrane.WebRTC.Signaling` channels via
  the `:source_signaling`/`:sink_signaling` opts.
  """

  use Membrane.Pipeline

  import Membrane.ChildrenSpec
  require Membrane.Pad

  alias Gemini.TermiteMicDemo
  alias Membrane.RawAudio

  alias Membrane.{
    FFmpeg.SWResample,
    Gemini,
    Pad,
    RawAudioParser,
    Realtimer,
    Tee,
    Time,
    Transcoder,
    WebRTC
  }

  @chunk_ms 40
  @gemini_input_format %RawAudio{sample_format: :s16le, channels: 1, sample_rate: 16_000}

  @spec submit_text(pipeline :: pid(), String.t()) :: {:text, String.t()}
  def submit_text(pipeline, text), do: send(pipeline, {:text, text})

  @spec reset_session(pipeline :: pid()) :: :reset_session
  def reset_session(pipeline), do: send(pipeline, :reset_session)

  @spec toggle_mute(pipeline :: pid()) :: :toggle_mute
  def toggle_mute(pipeline), do: send(pipeline, :toggle_mute)

  @impl true
  def handle_init(_ctx, opts) do
    app = Keyword.fetch!(opts, :app)
    source_signaling = Keyword.fetch!(opts, :source_signaling)
    sink_signaling = Keyword.fetch!(opts, :sink_signaling)
    {[spec: spec(app, source_signaling, sink_signaling)], %{app: app}}
  end

  @impl true
  def handle_playing(_ctx, state) do
    # Bootstrap handshake the App's handle_continue/2 blocks on before creating
    # the terminal (see Gemini.TermiteMicDemo.App's moduledoc).
    send(state.app.pid, {:pipeline_playing, self()})
    {[], state}
  end

  @impl true
  def handle_info({:text, _text} = msg, _ctx, state),
    do: {[notify_child: {:text_source, msg}], state}

  @impl true
  def handle_info(:reset_session, _ctx, state),
    do: {[notify_child: {:gemini, :reset_session}], state}

  @impl true
  def handle_info(:toggle_mute, _ctx, state),
    do: {[notify_child: {:mute_filter, :toggle_mute}], state}

  defp spec(app, source_signaling, sink_signaling) do
    [
      # audio pipeline:
      # WebRTC source -> processing -> gemini -> processing -> WebRTC sink
      child(:webrtc_source, %WebRTC.Source{signaling: source_signaling})
      |> via_out(Pad.ref(:output, :main_audio), options: [kind: :audio])
      |> child(:input_transcoder, %Transcoder{output_stream_format: @gemini_input_format})
      |> child(:input_resampler, %SWResample.Converter{output_stream_format: @gemini_input_format})
      |> child(:mute_filter, TermiteMicDemo.MuteFilter)
      |> child(:mic_pts_normalizer, %RawAudioParser{overwrite_pts?: true})
      |> child(:mic_chunker, %TermiteMicDemo.ChunkerFilter{
        chunk_duration: Time.milliseconds(@chunk_ms)
      })
      |> child(:mic_tee, Tee)
      |> via_out(Pad.ref(:output, :main))
      |> via_in(:audio_input)
      |> child(:gemini, Gemini.Bin)
      |> child(:gemini_pts_normalizer, %RawAudioParser{overwrite_pts?: true})
      |> child(:gemini_chunker, %TermiteMicDemo.ChunkerFilter{
        chunk_duration: Time.milliseconds(@chunk_ms)
      })
      |> child(:gemini_tee, Tee)
      |> via_out(Pad.ref(:output, :main))
      |> child(:output_transcoder, %Transcoder{output_stream_format: Membrane.Opus})
      |> via_in(Pad.ref(:input, :main_audio), options: [kind: :audio])
      |> child(:webrtc_sink, %WebRTC.Sink{
        signaling: sink_signaling,
        tracks: [:audio]
      }),
      # text messages -> gemini
      child(:text_source, TermiteMicDemo.TextSource)
      |> via_in(:text_input)
      |> get_child(:gemini),
      # tee the audio samples for the TUI to visualize
      get_child(:mic_tee)
      |> via_out(Pad.ref(:output, :tui))
      |> child(:mic_realtimer, Realtimer)
      |> child(:mic_tui_sink, %TermiteMicDemo.TuiSink{
        origin: :client,
        app: app
      }),
      get_child(:gemini_tee)
      |> via_out(Pad.ref(:output, :tui))
      |> child(:gemini_realtimer, Realtimer)
      |> child(:gemini_tui_sink, %TermiteMicDemo.TuiSink{
        origin: :server,
        app: app
      })
    ]
  end
end
```

## Start the pipeline + TUI

The cell below owns the lifecycle: it kills any previous run, then spawns a
runner that creates the two signalling channels and the bridge widget, starts
`Gemini.TermiteMicDemo.Pipeline` under the TUI `App`, waits for it to enter
`:playing`, then brings up the Termite TUI. The bridge widget is rendered
side-by-side with the terminal at the bottom of the cell.

```elixir
Logger.configure(level: :warning)

runner_name = :gemini_demo_app_runner

case Process.whereis(runner_name) do
  nil ->
    :ok

  pid ->
    ref = Process.monitor(pid)
    Process.exit(pid, :shutdown)

    receive do
      {:DOWN, ^ref, :process, ^pid, _} -> :ok
    after
      5_000 -> :ok
    end
end

parent = self()

spawn_link(fn ->
  Process.register(self(), runner_name)

  source_signaling = Membrane.WebRTC.Signaling.new()
  sink_signaling = Membrane.WebRTC.Signaling.new()

  bridge = TermiteMicDemo.WebRTCBridge.new(source_signaling, sink_signaling)

  send(parent, {:bridge_ready, bridge})

  app =
    TermiteMicDemo.App.new(
      pipeline: TermiteMicDemo.Pipeline,
      source_signaling: source_signaling,
      sink_signaling: sink_signaling,
      terminal_factory: fn -> Termite.Terminal.start(adapter: KinoTermite.Adapter, rows: 40) end
    )

  terminal = TermiteMicDemo.App.get_terminal(app)
  send(parent, {:terminal_ready, terminal})
  Process.sleep(:infinity)
end)

bridge =
  receive do
    {:bridge_ready, bridge} -> bridge
  end

bridge
```

Click `Connect` above and run the cell below to wait for the chatbot TUI to show up. You can speak with Gemini or send text messages using the chat prompt. Available chat commands:

```
/mute — mute / unmute the mic
/debug — toggle the debug event log
/clear — reset the conversation
```

```elixir
AwaitBridge.await_connected(bridge)
KinoTermite.output(  receive do
    {:terminal_ready, t} -> t
  after
    30_000 -> raise "terminal never started (did the pipeline reach :playing?)"
  end)
```

After this cell runs, click **Connect** in the bridge panel and start talking.
Keyboard shortcuts in the TUI:

* `m` — mute / unmute the mic
* `d` — toggle the debug event log
* type a prompt and press Enter to send text to Gemini
* `/clear` — reset the conversation

